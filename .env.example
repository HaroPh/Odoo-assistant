# ERP AI Assistant — copy thành .env rồi đổi mọi giá trị change_me
# .env phải được git-ignore.

# ─── CẦN NGAY (core bring-up) ────────────────────────────────────────────────
# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password

# LiteLLM gateway
LITELLM_MASTER_KEY=sk-change_me_master_key      # login Admin UI tại :4000/ui
LITELLM_SALT_KEY=change_me_salt_key             # mã hoá model key trong DB
LITELLM_AGENT_KEY=sk-change_me_agent_virtualkey # virtual key riêng cho backend (tạo trong UI)

# ─── CẦN Ở PHASE 1 (khi build MCP + backend) ────────────────────────────────
# Security
JWT_SECRET=change_me_very_long_random_string_min_32_chars
WEBUI_SECRET_KEY=change_me_random_string
INTERNAL_API_KEY=change_me

# Odoo (read-only Phase 1) — trỏ tới Odoo có sẵn hoặc container odoo profile
ODOO_URL=http://host.docker.internal:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=change_me

# SQL Server (host) — DÙNG LOGIN READ-ONLY (ai_readonly, chỉ db_datareader) — TAD v1.1 §3.1
SQLSERVER_HOST=host.docker.internal
SQLSERVER_PORT=1433
SQLSERVER_DB=YourDatabase
SQLSERVER_USER=ai_readonly
SQLSERVER_PASSWORD=change_me

# Documents (Phase 2)
DOCUMENTS_PATH=D:/Project/backend/src/rag/seed
