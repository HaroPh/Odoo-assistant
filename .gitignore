pgdata/
data/
*.log
logs/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Superpowers scratch (ledger is git-ignored scratch by design)
.superpowers/

# Internal planning docs (not project deliverables)
docs/superpowers/

# RAG test fixtures — generated at test-run time or manually dropped in for
